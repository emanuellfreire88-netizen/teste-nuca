generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(uuid())
  full_name       String
  email           String    @unique
  password        String
  role            String    @default("Viewer") // Admin, Operator, Viewer
  status          String    @default("active") // active, inactive
  profile_photo   String?
  must_change_password Boolean @default(true)  // User must change password on first login
  two_factor_enabled Boolean @default(false)
  two_factor_secret  String?
  verification_code       String?  // 6-digit code for 2FA email verification
  verification_code_expires DateTime?  // expiry time for the verification code
  failed_login_attempts Int  @default(0)
  locked_until    DateTime?
  last_login      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  attendance_records AttendanceRecord[]
  action_logs     ActionLog[]
  events          Event[]
  added_participants EventParticipant[]
  support_tickets SupportTicket[]  @relation("TicketCreator")
  support_messages SupportMessage[]
  assigned_tickets SupportTicket[] @relation("TicketAssignee")
  user_schools    UserSchool[]
  calendar_events CalendarEvent[]
  dropout_follow_ups DropoutFollowUp[]
  notifications  Notification[]
  sync_records   SyncRecord[]
  verified_documents StudentDocument[]
  student_transfers StudentTransfer[]
  document_templates DocumentTemplate[]

  @@map("users")
}

/// Junction table linking an Operator user to the School(s) they can access.
/// Admins implicitly have access to all schools (no rows needed).
model UserSchool {
  id        String   @id @default(uuid())
  user_id   String
  school_id String
  created_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  school School @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@unique([user_id, school_id])
  @@map("user_schools")
}

model School {
  id            String   @id @default(uuid())
  name          String
  address       String?
  phone         String?
  email         String?
  director_name String?
  opening_hours String?
  school_photo  String?
  latitude      Float?
  longitude     Float?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  students        Student[]
  events          Event[]
  user_schools    UserSchool[]
  calendar_events CalendarEvent[]
  transfers_from  StudentTransfer[] @relation("TransferFrom")
  transfers_to    StudentTransfer[] @relation("TransferTo")

  @@map("schools")
}

model Student {
  id              String   @id @default(uuid())
  full_name       String
  cpf             String?  @unique
  rg              String?
  date_of_birth   DateTime?
  blood_type      String?
  special_needs   String?
  medications     String?
  class           String?
  grade           String?
  phone           String?
  address         String?
  guardian_name   String?
  guardian_phone  String?
  guardian_email  String?
  emergency_contact String?
  school_id       String
  status          String   @default("active") // active, inactive
  photo           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  school          School   @relation(fields: [school_id], references: [id])
  attendance_records AttendanceRecord[]
  event_participations EventParticipant[]
  badges          ParticipationBadge[]
  dropout_risk_assessments DropoutRiskAssessment[]
  dropout_follow_ups DropoutFollowUp[]
  related_notifications Notification[]
  documents      StudentDocument[]
  transfers_from StudentTransfer[]

  @@map("students")
}

model ParticipationBadge {
  id          String   @id @default(uuid())
  student_id  String
  badge_type  String   // e.g., "5_events", "10_events", "20_events", "monthly_winner"
  earned_at   DateTime @default(now())

  student     Student  @relation(fields: [student_id], references: [id])

  @@unique([student_id, badge_type])
  @@map("participation_badges")
}

model AttendanceRecord {
  id          String   @id @default(uuid())
  student_id  String
  date        DateTime
  status      String   // present, absent
  created_by  String
  created_at  DateTime @default(now())

  student     Student  @relation(fields: [student_id], references: [id])
  user        User     @relation(fields: [created_by], references: [id])

  @@unique([student_id, date])
  @@map("attendance_records")
}

model ActionLog {
  id           String   @id @default(uuid())
  user_id      String?
  action_type  String   // login, logout, create_student, update_student, delete_student, create_school, update_school, delete_school, create_user, update_user, delete_user, export_report, backup
  description  String
  ip_address   String?
  device       String?
  created_at   DateTime @default(now())

  user         User?    @relation(fields: [user_id], references: [id])

  @@map("action_logs")
}

model Session {
  id           String   @id @default(uuid())
  user_id      String
  token        String   @unique
  expires_at   DateTime
  created_at   DateTime @default(now())

  @@map("sessions")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  status      String   @default("upcoming") // upcoming, ongoing, completed, cancelled
  created_by  String
  photo_url   String?
  school_id   String?
  category    String   @default("other") // sports, cultural, party, academic, other
  public_certificates Boolean @default(false) // when true, this event's certificates appear on the public link
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  creator     User     @relation(fields: [created_by], references: [id])
  school      School?  @relation(fields: [school_id], references: [id])
  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  id          String   @id @default(uuid())
  event_id    String
  student_id  String
  attended    Boolean  @default(false)
  notes       String?
  added_by    String?
  added_at    DateTime @default(now())
  created_at  DateTime @default(now())

  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [student_id], references: [id])
  adder       User?    @relation(fields: [added_by], references: [id])

  @@unique([event_id, student_id])
  @@map("event_participants")
}

model SupportTicket {
  id          String    @id @default(uuid())
  protocol    String    @unique  // e.g., "SUP-2026-0001"
  subject     String
  status      String    @default("open") // open, in_progress, resolved, closed
  priority    String    @default("normal") // low, normal, high, urgent
  user_id     String
  assigned_to String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user        User      @relation("TicketCreator", fields: [user_id], references: [id])
  assignee    User?     @relation("TicketAssignee", fields: [assigned_to], references: [id])
  messages    SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id          String    @id @default(uuid())
  ticket_id   String
  sender_id   String
  content     String
  is_read     Boolean   @default(false)
  created_at  DateTime  @default(now())

  ticket      SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  sender      User      @relation(fields: [sender_id], references: [id])

  @@map("support_messages")
}

model CalendarEvent {
  id               String    @id @default(uuid())
  title            String
  description      String?
  date             DateTime
  end_date         DateTime?
  type             String    @default("event")  // event, reminder, holiday, meeting, announcement
  color            String?
  location         String?   // destination for trips/activities
  departure_time   String?   // expected departure time (HH:mm)
  return_time      String?   // expected return time (HH:mm)
  responsible_name String?   // person responsible for the trip
  observations     String?   // additional notes
  school_id        String?
  created_by       String
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  school      School?   @relation(fields: [school_id], references: [id])
  creator     User      @relation(fields: [created_by], references: [id])

  @@map("calendar_events")
}

// ─── Dropout Detection Models ───

model DropoutRiskAssessment {
  id                       String   @id @default(uuid())
  student_id               String
  risk_level               String   // low, attention, medium, high
  score                    Float    @default(0) // 0-100 risk score
  reasons                  String   // JSON array of reasons that triggered the alert
  attendance_percentage    Float    @default(0)
  consecutive_absences     Int      @default(0)
  days_without_participation Int    @default(0)
  previous_risk_level      String?  // previous assessment level for tracking evolution
  calculated_at            DateTime @default(now())

  student                  Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([risk_level])
  @@index([student_id, calculated_at])
  @@map("dropout_risk_assessments")
}

model DropoutFollowUp {
  id              String   @id @default(uuid())
  student_id      String
  action_type     String   // call, contact_guardian, home_visit, conversation, returned
  description     String?
  responsible_id  String
  notes           String?
  created_at      DateTime @default(now())

  student         Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  responsible     User     @relation(fields: [responsible_id], references: [id])

  @@index([student_id])
  @@map("dropout_follow_ups")
}

// ─── Notification Model ───

model Notification {
  id                String   @id @default(uuid())
  user_id           String
  type              String   // dropout_alert, long_absence, low_attendance, offline_sync, info
  title             String
  message           String
  read              Boolean  @default(false)
  related_student_id String?
  created_at        DateTime @default(now())

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  student           Student? @relation(fields: [related_student_id], references: [id], onDelete: SetNull)

  @@index([user_id, read])
  @@index([user_id, created_at])
  @@map("notifications")
}

// ─── Offline Sync Record ───

model SyncRecord {
  id              String   @id @default(uuid())
  device_id       String
  user_id         String
  last_sync_at    DateTime @default(now())
  sync_status     String   @default("synced") // synced, pending, syncing, error
  pending_count   Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([device_id, user_id])
  @@map("sync_records")
}

// ─── Student Document Checklist ───

model StudentDocument {
  id            String    @id @default(uuid())
  student_id    String
  document_type String    // birth_certificate, residence_proof, vaccination_card, photo_3x4, rg_copy, cpf_copy, medical_report, enrollment_form, income_proof, other
  status        String    @default("pending") // pending, delivered, verified
  notes         String?
  delivered_at  DateTime?
  verified_by   String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  student       Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  verifier      User?     @relation(fields: [verified_by], references: [id])

  @@unique([student_id, document_type])
  @@index([student_id])
  @@index([status])
  @@map("student_documents")
}

// ─── Student Transfer Between Schools ───

model StudentTransfer {
  id              String   @id @default(uuid())
  student_id      String
  from_school_id  String
  to_school_id    String
  reason          String?
  transferred_by  String
  transferred_at  DateTime @default(now())

  student         Student  @relation(fields: [student_id], references: [id])
  from_school     School   @relation("TransferFrom", fields: [from_school_id], references: [id])
  to_school       School   @relation("TransferTo", fields: [to_school_id], references: [id])
  transferred_by_user User @relation(fields: [transferred_by], references: [id])

  @@index([student_id])
  @@index([from_school_id])
  @@index([to_school_id])
  @@map("student_transfers")
}

// ─── Document Template Model ───

model DocumentTemplate {
  id           String   @id @default(uuid())
  name         String   @unique  // e.g., "authorization_exit", "enrollment_declaration"
  display_name String   // user-friendly name, e.g., "Autorização de Saída"
  description  String?  // optional description of this template
  header_text  String?  // custom header text (replaces default)
  body_text    String?  // custom body/intro text before student sections
  footer_text  String?  // custom footer text
  declaration  String?  // declaration text for each student section
  is_active    Boolean  @default(true)
  created_by   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  creator      User?    @relation(fields: [created_by], references: [id])

  @@map("document_templates")
}
