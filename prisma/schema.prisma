generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  full_name       String
  email           String    @unique
  password        String
  role            String    @default("Viewer") // Admin, Operator, Viewer
  status          String    @default("active") // active, inactive
  profile_photo   String?
  two_factor_enabled Boolean @default(false)
  two_factor_secret  String?
  failed_login_attempts Int  @default(0)
  locked_until    DateTime?
  last_login      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  attendance_records AttendanceRecord[]
  action_logs     ActionLog[]

  @@map("users")
}

model School {
  id            String   @id @default(uuid())
  name          String
  address       String?
  phone         String?
  email         String?
  director_name String?
  opening_hours String?
  school_photo  String?
  latitude      Float?
  longitude     Float?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  students      Student[]

  @@map("schools")
}

model Student {
  id              String   @id @default(uuid())
  full_name       String
  cpf             String?  @unique
  rg              String?
  date_of_birth   DateTime?
  blood_type      String?
  special_needs   String?
  medications     String?
  class           String?
  grade           String?
  phone           String?
  address         String?
  guardian_name   String?
  guardian_phone  String?
  guardian_email  String?
  emergency_contact String?
  school_id       String
  status          String   @default("active") // active, inactive
  photo           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  school          School   @relation(fields: [school_id], references: [id])
  attendance_records AttendanceRecord[]

  @@map("students")
}

model AttendanceRecord {
  id          String   @id @default(uuid())
  student_id  String
  date        DateTime
  status      String   // present, absent
  created_by  String
  created_at  DateTime @default(now())

  student     Student  @relation(fields: [student_id], references: [id])
  user        User     @relation(fields: [created_by], references: [id])

  @@unique([student_id, date])
  @@map("attendance_records")
}

model ActionLog {
  id           String   @id @default(uuid())
  user_id      String?
  action_type  String   // login, logout, create_student, update_student, delete_student, create_school, update_school, delete_school, create_user, update_user, delete_user, export_report, backup
  description  String
  ip_address   String?
  device       String?
  created_at   DateTime @default(now())

  user         User?    @relation(fields: [user_id], references: [id])

  @@map("action_logs")
}

model Session {
  id           String   @id @default(uuid())
  user_id      String
  token        String   @unique
  expires_at   DateTime
  created_at   DateTime @default(now())

  @@map("sessions")
}
