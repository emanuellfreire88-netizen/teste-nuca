generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(uuid())
  full_name       String
  email           String    @unique
  password        String
  role            String    @default("Viewer") // Admin, Operator, Viewer
  status          String    @default("active") // active, inactive
  profile_photo   String?
  must_change_password Boolean @default(true)  // User must change password on first login
  two_factor_enabled Boolean @default(false)
  two_factor_secret  String?
  failed_login_attempts Int  @default(0)
  locked_until    DateTime?
  last_login      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  attendance_records AttendanceRecord[]
  action_logs     ActionLog[]
  events          Event[]
  added_participants EventParticipant[]
  support_tickets SupportTicket[]  @relation("TicketCreator")
  support_messages SupportMessage[]
  assigned_tickets SupportTicket[] @relation("TicketAssignee")

  @@map("users")
}

model School {
  id            String   @id @default(uuid())
  name          String
  address       String?
  phone         String?
  email         String?
  director_name String?
  opening_hours String?
  school_photo  String?
  latitude      Float?
  longitude     Float?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  students      Student[]
  events        Event[]

  @@map("schools")
}

model Student {
  id              String   @id @default(uuid())
  full_name       String
  cpf             String?  @unique
  rg              String?
  date_of_birth   DateTime?
  blood_type      String?
  special_needs   String?
  medications     String?
  class           String?
  grade           String?
  phone           String?
  address         String?
  guardian_name   String?
  guardian_phone  String?
  guardian_email  String?
  emergency_contact String?
  school_id       String
  status          String   @default("active") // active, inactive
  photo           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  school          School   @relation(fields: [school_id], references: [id])
  attendance_records AttendanceRecord[]
  event_participations EventParticipant[]
  badges          ParticipationBadge[]

  @@map("students")
}

model ParticipationBadge {
  id          String   @id @default(uuid())
  student_id  String
  badge_type  String   // e.g., "5_events", "10_events", "20_events", "monthly_winner"
  earned_at   DateTime @default(now())

  student     Student  @relation(fields: [student_id], references: [id])

  @@unique([student_id, badge_type])
  @@map("participation_badges")
}

model AttendanceRecord {
  id          String   @id @default(uuid())
  student_id  String
  date        DateTime
  status      String   // present, absent
  created_by  String
  created_at  DateTime @default(now())

  student     Student  @relation(fields: [student_id], references: [id])
  user        User     @relation(fields: [created_by], references: [id])

  @@unique([student_id, date])
  @@map("attendance_records")
}

model ActionLog {
  id           String   @id @default(uuid())
  user_id      String?
  action_type  String   // login, logout, create_student, update_student, delete_student, create_school, update_school, delete_school, create_user, update_user, delete_user, export_report, backup
  description  String
  ip_address   String?
  device       String?
  created_at   DateTime @default(now())

  user         User?    @relation(fields: [user_id], references: [id])

  @@map("action_logs")
}

model Session {
  id           String   @id @default(uuid())
  user_id      String
  token        String   @unique
  expires_at   DateTime
  created_at   DateTime @default(now())

  @@map("sessions")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  date        DateTime
  location    String?
  status      String   @default("upcoming") // upcoming, ongoing, completed, cancelled
  created_by  String
  photo_url   String?
  school_id   String?
  category    String   @default("other") // sports, cultural, party, academic, other
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  creator     User     @relation(fields: [created_by], references: [id])
  school      School?  @relation(fields: [school_id], references: [id])
  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  id          String   @id @default(uuid())
  event_id    String
  student_id  String
  attended    Boolean  @default(false)
  notes       String?
  added_by    String?
  added_at    DateTime @default(now())
  created_at  DateTime @default(now())

  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [student_id], references: [id])
  adder       User?    @relation(fields: [added_by], references: [id])

  @@unique([event_id, student_id])
  @@map("event_participants")
}

model SupportTicket {
  id          String    @id @default(uuid())
  protocol    String    @unique  // e.g., "SUP-2026-0001"
  subject     String
  status      String    @default("open") // open, in_progress, resolved, closed
  priority    String    @default("normal") // low, normal, high, urgent
  user_id     String
  assigned_to String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user        User      @relation("TicketCreator", fields: [user_id], references: [id])
  assignee    User?     @relation("TicketAssignee", fields: [assigned_to], references: [id])
  messages    SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id          String    @id @default(uuid())
  ticket_id   String
  sender_id   String
  content     String
  is_read     Boolean   @default(false)
  created_at  DateTime  @default(now())

  ticket      SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  sender      User      @relation(fields: [sender_id], references: [id])

  @@map("support_messages")
}
